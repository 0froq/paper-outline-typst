@article{winslow2018,
  title = {Global Lake Response to the Recent Warming Hiatus},
  author = {Winslow, Luke A and Leach, Taylor H and Rose, Kevin C},
  year = 2018,
  month = may,
  journal = {Environmental Research Letters},
  volume = {13},
  number = {5},
  pages = {54005},
  issn = {1748-9326},
  doi = {10.1088/1748-9326/aab9d7},
  urldate = {2025-12-16},
  abstract = {Understanding temporal variability in lake warming rates over decadal scales is important for understanding observed change in aquatic systems. We analyzed a global dataset of lake surface water temperature observations (1985-2009) to examine how lake temperatures responded to a recent global air temperature warming hiatus (1998-2012). Prior to the hiatus (1985-1998), surface water temperatures significantly increased at an average rate of 0.532 \textopenbullet C decade-1 (\textpm 0.214). In contrast, water temperatures did not change significantly during the hiatus (average rate -0.087 \textopenbullet C decade-1 \textpm 0.223). Overall, 83\% of lakes in our dataset (129 of 155) had faster warming rates during the pre-hiatus period than during the hiatus period. These results demonstrate that lakes have exhibited decadal-scale variability in warming rates coherent with global air temperatures and represent an independent line of evidence for the recent warming hiatus. Our analyses provide evidence that lakes are sentinels of broader climatological processes and indicate that warming rates based on datasets where a large proportion of observations were collected during the hiatus period may underestimate longer-term trends.},
  langid = {english},
  keywords = {/unread},
  annotation = {remark: Using global lake surface temperature data (1985-2009), this study in climate change examined lake responses to the recent warming hiatus (1998-2012). It found lake warming rates slowed significantly during the hiatus compared to prior decades, aligning with air temperature trends and highlighting lakes as climate sentinels.},
  file = {/Users/oQ/Library/Mobile Documents/com~apple~CloudDocs/papers/winslow2018_global_lake_response_to_the_recent_warming_hiatus.pdf}
}

@article{woolway2017,
  title = {Warming of {{Central European}} Lakes and Their Response to the 1980s Climate Regime Shift},
  author = {Woolway, R. Iestyn and Dokulil, Martin T. and Marszelewski, Wlodzimierz and Schmid, Martin and Bouffard, Damien and Merchant, Christopher J.},
  year = 2017,
  month = jun,
  journal = {Climatic Change},
  volume = {142},
  number = {3},
  pages = {505--520},
  issn = {1573-1480},
  doi = {10.1007/s10584-017-1966-4},
  urldate = {2025-12-03},
  abstract = {Lake surface water temperatures (LSWTs) are sensitive to atmospheric warming and have previously been shown to respond to regional changes in the climate. Using a combination of in situ and simulated surface temperatures from 20 Central European lakes, with data spanning between 50 and {$\sim$}100~years, we investigate the long-term increase in annually averaged LSWT. We demonstrate that Central European lakes are warming most in spring and experience a seasonal variation in LSWT trends. We calculate significant LSWT warming during the past few decades and illustrate, using a sequential t test analysis of regime shifts, a substantial increase in annually averaged LSWT during the late 1980s, in response to an abrupt shift in the climate. Surface air temperature measurements from 122 meteorological stations situated throughout Central Europe demonstrate similar increases at this time. Climatic modification of LSWT has numerous consequences for water quality and lake ecosystems. Quantifying the response of LSWT increase to large-scale and abrupt climatic shifts is essential to understand how lakes will respond in the future.},
  langid = {english},
  keywords = {/unread},
  annotation = {remark: Analysis of 50--100 years of data from 20 Central European lakes reveals significant spring-dominant lake surface warming and a sharp temperature rise following the late-1980s climate shift.},
  file = {/Users/oQ/Library/Mobile Documents/com~apple~CloudDocs/papers/woolway2017_warming_of_central_european_lakes_and_their_respon.pdf}
}

