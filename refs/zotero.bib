@article{herrera-estrada2017,
  title = {Spatiotemporal Dynamics of Global Drought},
  author = {{Herrera-Estrada}, Julio E. and Satoh, Yusuke and Sheffield, Justin},
  year = 2017,
  journal = {Geophysical Research Letters},
  volume = {44},
  number = {5},
  pages = {2254--2263},
  issn = {1944-8007},
  doi = {10.1002/2016GL071768},
  urldate = {2024-05-09},
  abstract = {Understanding the evolution and physical drivers of drought is critical to informing forecasting efforts. One aspect that has seldom been explored is the joint evolution of droughts in space and time. Most studies fix the reference area and focus on their temporal variability or study their spatial heterogeneity over fixed durations. This work implements a Lagrangian approach by aggregating contiguous areas under drought into clusters. These clusters become the frame of reference and are tracked as they evolve through space and time. Clusters were identified from soil moisture data from the Climate Forecast System Reanalysis (1979--2009). Evapotranspiration, moisture fluxes, and precipitation were used to explore the relevance of possible mechanisms of drought propagation. While most droughts remain near their origin, the centroid of 10\% of clusters traveled at least 1400--3100 km, depending on the continent. This approach also revealed that large-scale droughts often lock into further growth and intensification.},
  copyright = {\copyright 2017. American Geophysical Union. All Rights Reserved.},
  langid = {english},
  lccn = {1},
  keywords = {/unread,cfsr_data,drought_evolution,drought_growth,drought_propagation,lagrangian_clusters,spatiotemporal_analysis},
  file = {/Users/oQ/Library/Mobile Documents/com~apple~CloudDocs/papers/herrera-estrada2017_spatiotemporal_dynamics_of_global_drought.pdf}
}

