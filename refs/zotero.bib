  file = {/Users/oQ/Library/Mobile Documents/com~apple~CloudDocs/papers/jones1997_extension_to_the_north_atlantic_oscillation_using.pdf}
}

@article{kartal2025,
  title = {Remote Sensing Evidence of Seasonal and Long-Term Warming in Lake Surface Water Temperature},
  author = {Kartal, Veysi},
  year = 2025,
  month = nov,
  journal = {Construction Systems \& Infrastructure},
  volume = {1},
  number = {1},
  pages = {23--39},
  issn = {3108-5768},
  doi = {10.65782/csin.6},
  urldate = {2026-03-26},
  abstract = {This study analyzed the trends in Lake Surface Water Temperature (LSWT) from 2001 to 2024 using both Mann--Kendall trend tests, Sen's slope estimator, and Innovative Trend Analysis (ITA). Annual and seasonal datasets revealed distinct warming patterns across all seasons, with varying magnitudes and statistical significance. The annual LSWT showed a statistically significant warming rate of +0.078 {$^\circ$}C/yr (p = 0.027), while the most pronounced seasonal increase occurred in winter (+0.122 {$^\circ$}C/yr, p = 0.0059). Spring and autumn exhibited weaker, non-significant warming (+0.086 {$^\circ$}C/yr and +0.089 {$^\circ$}C/yr, respectively), and summer displayed only a slight, statistically insignificant increase (+0.027 {$^\circ$}C/yr/, p = 0.333). The ITA plots further confirmed that the second half of the study period (2013--2024) was consistently warmer than the first (2001--2012), especially during winter and autumn. Overall, the findings indicate a clear long-term warming trend consistent with global climate warming impacts on inland waters, with substantial implications for lake thermal dynamics, stratification, and ecosystem functioning.           ,              ~  ~  Bu \c cal\i\c sma, Mann--Kendall trend testleri, Sen'in e\u gim tahmincisi ve Yenilik\c ci Trend Analizi (ITA) kullan\i larak 2001'den 2024'e kadar G\"ol Y\"uzey Suyu S\i cakl\i\u g\i (LSWT) trendlerini analiz etmi\c stir. Y\i ll\i k ve mevsimsel veri setleri,t\"um mevsimlerde farkl\i{} b\"uy\"ukl\"uklerde ve istatistiksel \"oneme sahip belirgin \i s\i nma e\u gilimleri ortaya koymu\c stur. Y\i ll\i k LSWT, istatistiksel olarak anlaml\i{} +0,078 {$^\circ$}C/y\i l (p = 0,027) \i s\i nma oran\i{} g\"osterirken, en belirgin mevsimsel art\i\c s k\i\c s aylar\i nda (+0,122 {$^\circ$}C/y\i l, p = 0,0059) meydana gelmi\c stir. \.Ilkbahar ve sonbahar, daha zay\i f, istatistiksel olarak anlaml\i{} olmayan bir \i s\i nma g\"osterdi (s\i ras\i yla +0,086 {$^\circ$}C/y\i l ve +0,089 {$^\circ$}C/y\i l), yaz ise sadece hafif, istatistiksel olarak anlaml\i{} olmayan bir art\i\c s g\"osterdi (+0,027 {$^\circ$}C/y\i l, p = 0,333). ITA grafikleri, \c cal\i\c sma d\"oneminin ikinci yar\i s\i n\i n (2013--2024) ilk yar\i s\i na (2001--2012) g\"ore, \"ozellikle k\i\c s ve sonbahar aylar\i nda, tutarl\i{} bir \c sekilde daha s\i cak oldu\u gunu teyit etmi\c stir. Genel olarak, bulgular, i\c c sulara k\"uresel iklim \i s\i nmas\i n\i n etkilerine uygun, g\"ol termal dinami\u gi, tabakala\c sma ve ekosistem i\c sleyi\c si \"uzerinde \"onemli etkileri olan, a\c c\i k bir uzun vadeli \i s\i nma e\u gilimi oldu\u gunu g\"ostermektedir.},
  copyright = {https://creativecommons.org/licenses/by/4.0},
  langid = {english},
  keywords = {/unread,climate_change_impact,ecosystem_functioning,lake_thermal_dynamics,lswt_warming_trend,seasonal_temperature_variation},
  file = {/Users/oQ/Library/Mobile Documents/com~apple~CloudDocs/papers/kartal2025_remote_sensing_evidence_of_seasonal_and_long-term.pdf}
}

