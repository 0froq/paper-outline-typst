  shorttitle = {Implementation of {{FAIR}} Principles in the {{IPCC}}},
  author = {Iturbide, Maialen and Fern{\'a}ndez, Jes{\'u}s and Guti{\'e}rrez, Jos{\'e} M. and Pirani, Anna and Huard, David and Al Khourdajie, Alaa and {Ba{\~n}o-Medina}, Jorge and Bedia, Joaquin and Casanueva, Ana and Cimadevilla, Ezequiel and Cofi{\~n}o, Antonio S. and De Felice, Matteo and {Diez-Sierra}, Javier and {Garc{\'i}a-D{\'i}ez}, Markel and Goldie, James and Herrera, Dimitris A. and Herrera, Sixto and Manzanas, Rodrigo and Milovac, Josipa and Radhakrishnan, Aparna and {San-Mart{\'i}n}, Daniel and Spinuso, Alessandro and Thyng, Kristen M. and Trenham, Claire and Yelek{\c c}i, {\"O}zge},
  year = 2022,
